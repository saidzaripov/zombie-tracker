# Zombie Tracker — environment template
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Read-only Postgres (the hackathon-distributed credential is in the
# Agency 2026 - Ottawa AI Hackathon information pack — request a copy from the
# hackathon organizers, or see the GovAlta/agency-26-hackathon README).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME"

# Anthropic API key — get one at https://console.anthropic.com/settings/keys
# Wrap in single quotes (Next.js's dotenv-expand can otherwise truncate keys
# containing $-like sequences).
ANTHROPIC_API_KEY='sk-ant-api03-...'
ANTHROPIC_MODEL="claude-sonnet-4-6"
